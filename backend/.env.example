# =============================================================================
# 数据库
# =============================================================================
# PostgreSQL 连接（按你本地 PG 的实际值改）
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ecotea

# CORS 允许的前端 origin（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 应用日志级别
LOG_LEVEL=INFO


# =============================================================================
# LLM 抽象层（M0）
# =============================================================================
# 主 provider；可选：openai / deepseek / qwen / moonshot / zhipu / anthropic
LLM_PROVIDER=openai

# 模型名（留空则用 provider 默认值）
# OpenAI 默认：     gpt-4o-mini
# DeepSeek 默认：   deepseek-chat
# Qwen 默认：       qwen-plus
# Moonshot 默认：   moonshot-v1-8k
# Zhipu 默认：      glm-4-plus
# Anthropic 默认：  claude-3-5-haiku-latest
LLM_MODEL=

# 通用调参
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=60
# LLM_MAX_TOKENS=4096        # 留空表示由 provider 自定

# -----------------------------------------------------------------------------
# 各 provider 的 API key（按需填，不用的留空）
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# DEEPSEEK_API_KEY=                # https://platform.deepseek.com/
# DASHSCOPE_API_KEY=               # 通义千问 https://dashscope.aliyuncs.com/
# MOONSHOT_API_KEY=                # 月之暗面 https://platform.moonshot.cn/
# ZHIPU_API_KEY=                   # 智谱 https://open.bigmodel.cn/
# ANTHROPIC_API_KEY=               # https://console.anthropic.com/


# =============================================================================
# RAG / 向量库（M1）
# =============================================================================
# Embedding provider；可选：huggingface（本地，零成本）/ openai / qwen
EMBEDDING_PROVIDER=huggingface

# embedding 模型（留空则用 provider 默认值）
# huggingface 默认：sentence-transformers/all-MiniLM-L6-v2
# openai      默认：text-embedding-3-small
# qwen        默认：text-embedding-v3
EMBEDDING_MODEL=

# ChromaDB 持久化目录（已 .gitignore）
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=domain_glossary
